# Flutterwave — primary payment connector (card, mobile money, bank transfer)
# Dashboard: https://dashboard.flutterwave.com/settings/apis
FLUTTERWAVE_SECRET_KEY=
# Dashboard: https://dashboard.flutterwave.com/settings/webhooks (the "secret hash", not a signing secret)
FLUTTERWAVE_WEBHOOK_HASH=

# Used by the Flutterwave gateway for redirect/logo URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
